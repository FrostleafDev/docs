---
import { Icon } from "@astrojs/starlight/components";
import type { ComponentProps } from "astro/types";

interface Props {
  icon?: ComponentProps<typeof Icon>["name"] | string;
  title: string;
  href: string;
  destructive?: boolean;
}

const { icon, title, href, destructive } = Astro.props;
const isCustomIcon = icon && (icon.includes('.') || icon.includes('/'));
---

<a href={href} class:list={["not-content", "card", destructive && "card-destructive"]}>
  <article class="sl-flex">
    <div class="title sl-flex">
      {icon && (
        /* Dieser Container ist das lila Feld */
        <div class="icon-box">
          {isCustomIcon ? (
            /* Nur dieses Bild bekommt den Weiß-Filter */
            <img src={icon} class="custom-icon-img" alt="" />
          ) : (
            <Icon name={icon as any} size="1.333em" />
          )}
        </div>
      )}
      <span set:html={title} />
      {destructive && <Icon name="warning" class="warning-icon" />}
    </div>
    <div class="body"><slot /></div>
  </article>
</a>

<style>
  /* Das lila Feld (Hintergrund des Icons) - Hier Größe angepasst */
  .icon-box {
    border: 1px solid var(--sl-card-border);
    background-color: var(--sl-card-bg);
    padding: 0.35rem; /* Etwas mehr Innenabstand */
    border-radius: 0.35rem; /* Leicht abgerundeter für den Look */
    width: 2.2rem; /* Von 1.6rem auf 2.2rem erhöht */
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* NUR das Schwert-Bild weiß machen */
  .custom-icon-img {
    width: 1.2rem;
    height: 1.2rem;
    object-fit: contain;
    filter: brightness(0) invert(1) !important;
  }

  .card {
    --sl-card-border: var(--sl-color-purple);
    --sl-card-bg: var(--sl-color-purple-low);
    border: 1px solid var(--sl-color-gray-5);
    background-color: var(--sl-color-black);
    padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
    border-radius: 0.25rem;
    text-decoration: none;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .card article { flex-direction: column; gap: 0.5rem; }

  /* HOVER: Hier wird die Karte beim Drüberfahren farbig */
  .card:hover {
    border-color: var(--sl-card-border) !important;
    background-color: var(--sl-card-bg) !important;
  }

  /* Farblogik für die Karten */
  .card:nth-child(4n + 1) { --sl-card-border: var(--sl-color-orange); --sl-card-bg: var(--sl-color-orange-low); }
  .card:nth-child(4n + 3) { --sl-card-border: var(--sl-color-green); --sl-card-bg: var(--sl-color-green-low); }
  .card:nth-child(4n + 4) { --sl-card-border: var(--sl-color-red); --sl-card-bg: var(--sl-color-red-low); }
  .card:nth-child(4n + 5) { --sl-card-border: var(--sl-color-blue); --sl-card-bg: var(--sl-color-blue-low); }

  .title {
    font-weight: 600;
    font-size: var(--sl-text-h4);
    display: flex;
    gap: 1rem;
    align-items: center;
    color: var(--sl-color-white);
  }

  .card .body {
    margin-top: 0.5rem;
    color: var(--sl-color-gray-3);
  }
</style>