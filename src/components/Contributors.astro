---
const contributors = ['derjozelot', 'WoozleCraft', 'Ultra-1239'];
---

<div class="contributor-grid">
  {contributors.map((user) => (
    <a href={`https://github.com/${user}`} target="_blank" rel="noopener noreferrer">
      <img
        src={`https://github.com/${user}.png?size=64`}
        alt={user}
        title={user}
      />
    </a>
  ))}
</div>

<style>
  .contributor-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .contributor-grid img {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 2px solid var(--sl-color-hairline);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .contributor-grid img:hover {
    transform: scale(1.1);
    border-color: var(--sl-color-accent);
  }
</style>